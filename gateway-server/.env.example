# ============================================
# Gateway Server — Environment Configuration
# ============================================
# Copy this file to .env and adjust values for your environment.
# Local defaults work out-of-the-box for single-machine development.

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local:   mongodb://localhost:27017/student-doc-repo
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/student-doc-repo
MONGO_URI=mongodb://localhost:27017/student-doc-repo

# JWT Authentication
JWT_SECRET=distributed-doc-repo-secret-key-2026
JWT_EXPIRE=7d

# Redis
# Option 1 — Full URL (takes priority):
# REDIS_URL=redis://default:<password>@<host>:<port>
# Option 2 — Host + Port (fallback):
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage Node URLs
# Local:       http://localhost:5001
# Distributed: http://<laptop-B-ip>:5001
STORAGE_NODE_1=http://localhost:5001
STORAGE_NODE_2=http://localhost:5002

# CORS — Allowed frontend origin
# Use * for development, restrict in production
# Example: http://192.168.1.101:5173
CORS_ORIGIN=*

# Replication
REPLICATION_FACTOR=2
