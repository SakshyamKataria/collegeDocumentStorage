# IMPORTANT: Rename this file to `.env.gateway`
# ALSO, for the frontend to build correctly with these variables, you must either
# run `set VITE_API_URL=http://<LAPTOP_A_IP>:5000/api` before docker compose build,
# OR copy these two VITE_ lines into a `.env` file in the root directory.
VITE_API_URL=http://<LAPTOP_A_IP>:5000/api
VITE_SOCKET_URL=http://<LAPTOP_A_IP>:5000

# CORS should allow the frontend port or be wildcard for LAN
CORS_ORIGIN=*
