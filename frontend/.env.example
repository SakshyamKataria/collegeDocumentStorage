# ============================================
# Frontend — Environment Configuration
# ============================================
# Copy this file to .env and adjust values for your environment.
# Vite requires env vars to be prefixed with VITE_ to be accessible in code.
# IMPORTANT: Changes require a dev server restart (or rebuild for production).

# API Base URL (must include /api path)
# Local:       http://localhost:5000/api
# Distributed: http://<gateway-laptop-ip>:5000/api
VITE_API_URL=http://localhost:5000/api

# Socket.IO URL (base URL WITHOUT /api)
# Local:       http://localhost:5000
# Distributed: http://<gateway-laptop-ip>:5000
VITE_SOCKET_URL=http://localhost:5000
