# ============================================
# Storage Node — Environment Configuration
# ============================================
# Copy this file to .env and adjust values for your environment.
# Local defaults work out-of-the-box for single-machine development.

# Node Identity
PORT=5001
NODE_ID=storage-node-1
NODE_ENV=development

# Self URL — The public URL other services use to reach THIS node.
# Local:       http://localhost:5001
# Distributed: http://<this-laptop-ip>:5001
SELF_URL=http://localhost:5001

# MongoDB
# Local:   mongodb://localhost:27017/storage-node-1-db
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/storage-node-1-db
MONGO_URI=mongodb://localhost:27017/storage-node-1-db

# Redis
# Option 1 — Full URL (takes priority):
# REDIS_URL=redis://default:<password>@<host>:<port>
# Option 2 — Host + Port (fallback):
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Peer Node (for replication)
# Local:       http://localhost:5002
# Distributed: http://<peer-laptop-ip>:5002
PEER_NODE_URL=http://localhost:5002
PEER_NODE_ID=storage-node-2

# Gateway
# Local:       http://localhost:5000
# Distributed: http://<gateway-laptop-ip>:5000
GATEWAY_URL=http://localhost:5000

# Heartbeat
HEARTBEAT_INTERVAL=5000
